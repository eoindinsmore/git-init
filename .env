# ── home-fund secrets ─ never commit this file, keep .env in .gitignore ──

# FRED — free key: fred.stlouisfed.org → My Account → API Keys
FRED_API_KEY=2d0a389e0f1c65b10d1f78d0872b5a7a

# e-Stat Japan — free registration: e-stat.go.jp (appId issued after signup)
ESTAT_APP_ID=

# e-Stat dataset to pull (optional; find an id via the statsList call first)
ESTAT_STATS_DATA_ID=

# Statistics Canada vector to pull (no key needed; vector shown on each table page)
STATCAN_VECTOR_ID=65201210

# EIA — free key: eia.gov/opendata (energy inputs for smelter cost work)
EIA_API_KEY=

# ── needed later in the build order, register when you get there ──

# INEGI Mexico — free token: inegi.org.mx developer portal
INEGI_API_TOKEN=

# KOSIS Korea — free key: kosis.kr OpenAPI
KOSIS_API_KEY=

# Destatis GENESIS-Online — free registration: www-genesis.destatis.de
DESTATIS_USER=
DESTATIS_PASSWORD=

# data.gov.in (India) — free key on registration
DATAGOVIN_API_KEY=
