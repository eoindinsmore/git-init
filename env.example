# Copy to .env (gitignore it) and fill in. Never commit or paste keys into Claude.

# Required — free key from https://fred.stlouisfed.org (API Keys under My Account)
FRED_API_KEY=

# Required for e-Stat — free registration at https://www.e-stat.go.jp (English portal available)
ESTAT_APP_ID=

# Optional — set after inspecting the estat_statslist fixture to pull a real dataset
ESTAT_STATS_DATA_ID=

# Optional — replace the placeholder with the StatCan vector you actually want
# (vector IDs are shown on each table page on the StatCan site)
STATCAN_VECTOR_ID=65201210
